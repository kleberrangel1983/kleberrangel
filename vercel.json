{
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/assets/ebook-dor-cronica.pdf",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/pdf"
        },
        {
          "key": "Content-Disposition",
          "value": "attachment; filename=Guia-Dor-Cronica-Sem-Cirurgia-Dr-Kleber.pdf"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/privacidade",
      "destination": "/politica-privacidade.html",
      "permanent": true
    },
    {
      "source": "/lgpd",
      "destination": "/politica-privacidade.html",
      "permanent": true
    },
    {
      "source": "/termos",
      "destination": "/termos.html",
      "permanent": true
    },
    {
      "source": "/politica-de-privacidade",
      "destination": "/politica-privacidade.html",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/coluna",
      "destination": "/coluna.html"
    },
    {
      "source": "/joelho",
      "destination": "/joelho.html"
    },
    {
      "source": "/ombro",
      "destination": "/ombro.html"
    },
    {
      "source": "/prp",
      "destination": "/prp.html"
    },
    {
      "source": "/medicina-regenerativa",
      "destination": "/medicina-regenerativa.html"
    },
    {
      "source": "/ozonoterapia-divinopolis",
      "destination": "/ozonoterapia-divinopolis.html"
    },
    {
      "source": "/lp-dor-coluna",
      "destination": "/lp-dor-coluna.html"
    },
    {
      "source": "/bloqueio-guiado-ultrassom-divinopolis",
      "destination": "/bloqueio-guiado-ultrassom-divinopolis.html"
    },
    {
      "source": "/prp-joelho-divinopolis",
      "destination": "/prp-joelho-divinopolis.html"
    },
    {
      "source": "/ozonioterapia-coluna-divinopolis",
      "destination": "/ozonioterapia-coluna-divinopolis.html"
    },
    {
      "source": "/blog",
      "destination": "/blog/index.html"
    },
    {
      "source": "/blog/:path*",
      "destination": "/blog/:path*.html"
    },
    {
      "source": "/formiga",
      "destination": "/formiga.html"
    },
    {
      "source": "/itauna",
      "destination": "/itauna.html"
    },
    {
      "source": "/nova-serrana",
      "destination": "/nova-serrana.html"
    },
    {
      "source": "/para-de-minas",
      "destination": "/para-de-minas.html"
    },
    {
      "source": "/politica-privacidade",
      "destination": "/politica-privacidade.html"
    }
  ]
}