{
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/assets/ebook-dor-cronica.pdf",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/pdf"
        },
        {
          "key": "Content-Disposition",
          "value": "attachment; filename=Guia-Dor-Cronica-Sem-Cirurgia-Dr-Kleber.pdf"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/privacidade",
      "destination": "/politica-privacidade.html",
      "permanent": true
    },
    {
      "source": "/lgpd",
      "destination": "/politica-privacidade.html",
      "permanent": true
    },
    {
      "source": "/coluna",
      "destination": "/coluna.html",
      "permanent": false
    },
    {
      "source": "/joelho",
      "destination": "/joelho.html",
      "permanent": false
    },
    {
      "source": "/prp",
      "destination": "/prp.html",
      "permanent": false
    },
    {
      "source": "/ombro",
      "destination": "/ombro.html",
      "permanent": false
    },
    {
      "source": "/medicina-regenerativa",
      "destination": "/medicina-regenerativa.html",
      "permanent": false
    },
    {
      "source": "/blog/dor-na-coluna",
      "destination": "/blog/dor-na-coluna.html",
      "permanent": false
    },
    {
      "source": "/blog/hernia-de-disco",
      "destination": "/blog/hernia-de-disco.html",
      "permanent": false
    },
    {
      "source": "/blog/artrose-joelho",
      "destination": "/blog/artrose-joelho.html",
      "permanent": false
    },
    {
      "source": "/blog/condromalacia",
